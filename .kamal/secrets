# Secrets are referenced from config/deploy.yml under env/secret,
# registry/password, etc. NEVER commit raw credentials — pull them
# from the host environment, a password manager, or Rails credentials.
#
# The Foundation deploy will likely use 1Password for team secrets.
# Until that's wired, these read from the local environment so an
# operator can run `bin/kamal deploy` with their own .env loaded.

# Rails master key for credentials decryption. Defaults to the
# checked-out config/master.key (which is in .gitignore).
RAILS_MASTER_KEY=$(cat config/master.key)

# GitHub Container Registry token. Generate at github.com/settings/tokens
# (scope: write:packages, read:packages) and export before deploying:
#   export KAMAL_REGISTRY_PASSWORD=ghp_xxxxxxxxxxxx
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Postgres password for the `db` accessory.
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# HMAC shared secret used by WebhooksController to verify ingest
# notifications from rails/rails CI. Mint a high-entropy value
# (e.g. `bin/rails secret`) and store in your password manager.
INGEST_WEBHOOK_SECRET=$INGEST_WEBHOOK_SECRET
