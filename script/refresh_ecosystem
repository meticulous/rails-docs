#!/usr/bin/env bash
# Re-runs script/ingest_gem across every non-rails ecosystem source.
# Versions are the latest patch of each minor lineage from each gem's
# 1.0+ release stream (skipping pre-1.0 previews — happy to expand if
# someone wants the 0.x history). Operator script — fires after an
# ingester change or when bootstrapping a new deployment.
#
#   ./script/refresh_ecosystem
#
# Logs to /tmp/refresh-ecosystem.log; per-version status to stdout.

set -uo pipefail

LOG=/tmp/refresh-ecosystem.log
: > "$LOG"

# Format: "<slug>  <version-without-v>  <github-repo>  <source-dirs>"
# Latest patch of each minor lineage, 1.0 onwards. Re-survey GitHub
# tags (`git ls-remote --tags --refs https://github.com/<repo>.git`)
# when refreshing — gems land new minors fairly often.
runs=(
  "globalid         1.0.1     rails/globalid           lib"
  "globalid         1.1.0     rails/globalid           lib"
  "globalid         1.2.1     rails/globalid           lib"
  "globalid         1.3.0     rails/globalid           lib"

  "importmap-rails  1.0.3     rails/importmap-rails    lib app"
  "importmap-rails  1.1.6     rails/importmap-rails    lib app"
  "importmap-rails  1.2.3     rails/importmap-rails    lib app"
  "importmap-rails  2.0.3     rails/importmap-rails    lib app"
  "importmap-rails  2.1.0     rails/importmap-rails    lib app"
  "importmap-rails  2.2.3     rails/importmap-rails    lib app"

  "jbuilder         2.4.1     rails/jbuilder           lib"
  "jbuilder         2.5.0     rails/jbuilder           lib"
  "jbuilder         2.6.4     rails/jbuilder           lib"
  "jbuilder         2.7.0     rails/jbuilder           lib"
  "jbuilder         2.8.0     rails/jbuilder           lib"
  "jbuilder         2.9.1     rails/jbuilder           lib"
  "jbuilder         2.10.2    rails/jbuilder           lib"
  "jbuilder         2.11.5    rails/jbuilder           lib"
  "jbuilder         2.12.0    rails/jbuilder           lib"
  "jbuilder         2.13.0    rails/jbuilder           lib"
  "jbuilder         2.14.1    rails/jbuilder           lib"

  "kamal            1.9.3     basecamp/kamal           lib"
  "kamal            2.0.0     basecamp/kamal           lib"
  "kamal            2.1.2     basecamp/kamal           lib"
  "kamal            2.2.2     basecamp/kamal           lib"
  "kamal            2.3.0     basecamp/kamal           lib"
  "kamal            2.4.0     basecamp/kamal           lib"
  "kamal            2.5.3     basecamp/kamal           lib"
  "kamal            2.6.1     basecamp/kamal           lib"
  "kamal            2.7.0     basecamp/kamal           lib"
  "kamal            2.8.2     basecamp/kamal           lib"
  "kamal            2.9.0     basecamp/kamal           lib"
  "kamal            2.10.1    basecamp/kamal           lib"
  "kamal            2.11.0    basecamp/kamal           lib"

  "propshaft        1.0.1     rails/propshaft          lib"
  "propshaft        1.1.0     rails/propshaft          lib"
  "propshaft        1.2.1     rails/propshaft          lib"
  "propshaft        1.3.2     rails/propshaft          lib"

  "solid_cable      1.0.6     rails/solid_cable        lib"
  "solid_cable      1.1.0     rails/solid_cable        lib"
  "solid_cable      2.0.2     rails/solid_cable        lib"
  "solid_cable      3.0.12    rails/solid_cable        lib"

  "solid_cache      1.0.10    rails/solid_cache        lib"

  "solid_queue      1.0.2     rails/solid_queue        lib app"
  "solid_queue      1.1.5     rails/solid_queue        lib app"
  "solid_queue      1.2.4     rails/solid_queue        lib app"
  "solid_queue      1.3.2     rails/solid_queue        lib app"
  "solid_queue      1.4.0     rails/solid_queue        lib app"

  "stimulus-rails   1.0.4     hotwired/stimulus-rails  lib"
  "stimulus-rails   1.1.1     hotwired/stimulus-rails  lib"
  "stimulus-rails   1.2.2     hotwired/stimulus-rails  lib"
  "stimulus-rails   1.3.4     hotwired/stimulus-rails  lib"

  "turbo-rails      1.3.3     hotwired/turbo-rails     lib app"
  "turbo-rails      1.4.0     hotwired/turbo-rails     lib app"
  "turbo-rails      1.5.0     hotwired/turbo-rails     lib app"
  "turbo-rails      2.0.23    hotwired/turbo-rails     lib app"
)

start=$(date +%s)
ok=0
fail=0

for entry in "${runs[@]}"; do
  read -r slug version repo dirs <<< "$entry"
  ts=$(date +%H:%M:%S)
  echo "[$ts] $slug $version  start" | tee -a "$LOG"
  if ./script/ingest_gem "$slug" "$version" "$repo" $dirs >>"$LOG" 2>&1; then
    ok=$((ok+1))
    echo "[$(date +%H:%M:%S)] $slug $version  ok" | tee -a "$LOG"
  else
    fail=$((fail+1))
    echo "[$(date +%H:%M:%S)] $slug $version  FAIL" | tee -a "$LOG"
  fi
done

elapsed=$(( $(date +%s) - start ))
printf -- "----\ndone in %dm  ok=%d  fail=%d\nlog: %s\n" \
  $((elapsed/60)) $ok $fail "$LOG"
