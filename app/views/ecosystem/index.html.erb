<% content_for :title, "Ruby on Rails Ecosystem" %>

<div class="ecosystem">
  <h1>Ecosystem</h1>
  <p class="home__lede">
    API documentation for the Foundation-maintained gems that complete the Rails stack.
  </p>

  <% if @sources.any? %>
    <div class="framework-grid">
      <% @sources.each do |source| %>
        <% latest = source.package_versions.where.not(ingested_at: nil).order(ord: :desc).first %>
        <article class="framework-card">
          <h3>
            <%= link_to source.display_name,
                        version_path(source_slug: source.slug, version: version_url_segment(latest)) %>
          </h3>
          <p class="muted">
            v<%= latest.channel %> ·
            <%= number_with_delimiter(latest.entity_versions.count) %> documented entities ·
            <%= link_to "GitHub", "https://github.com/#{source.github_repo}", target: "_blank", rel: "noopener noreferrer" %>
          </p>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="muted">No ecosystem gems ingested yet.</p>
  <% end %>
</div>
