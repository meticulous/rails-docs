<!DOCTYPE html>
<html lang="en" data-controller="theme">
  <head>
    <title><%= content_for(:title) || "Ruby on Rails API" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ruby on Rails API">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% if (canonical = content_for(:canonical_url)).present? %>
      <link rel="canonical" href="<%= canonical %>">
    <% end %>

    <% if (description = content_for(:meta_description)).present? %>
      <meta name="description" content="<%= description %>">
    <% end %>

    <meta property="og:type" content="<%= content_for(:og_type).presence || 'article' %>">
    <meta property="og:title" content="<%= content_for(:title) || 'Ruby on Rails API' %>">
    <% if (description = content_for(:meta_description)).present? %>
      <meta property="og:description" content="<%= description %>">
    <% end %>
    <% if (canonical = content_for(:canonical_url)).present? %>
      <meta property="og:url" content="<%= canonical %>">
    <% end %>
    <meta property="og:site_name" content="Ruby on Rails API">
    <% if (og_image = content_for(:og_image)).present? %>
      <meta property="og:image" content="<%= og_image %>">
      <meta name="twitter:image" content="<%= og_image %>">
    <% end %>

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:title) || 'Ruby on Rails API' %>">
    <% if (description = content_for(:meta_description)).present? %>
      <meta name="twitter:description" content="<%= description %>">
    <% end %>

    <%# Per-page active context for the lazy-loaded module-nav frame.
        The frame body is version-cached and shared across pages; these
        tiny tags let the module-nav Stimulus controller highlight the
        current entity's row + namespace trail client-side. %>
    <meta name="nav-active-fqn" content="<%= nav_active_fqn %>">
    <meta name="nav-active-framework" content="<%= current_framework_slug %>">
    <meta name="nav-upstream-fqns" content="<%= nav_upstream_fqns.to_json %>">

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="keyboard search-palette"
        data-action="keydown.meta+k@window->search-palette#open keydown.ctrl+k@window->search-palette#open">
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header class="site-header">
      <div class="site-header__inner">
        <%= link_to root_path, class: "site-header__brand", title: "API Guides home" do %>
          <%= image_tag "logo_rails-circle.svg", class: "site-header__logo", alt: "" %>
          <span class="site-header__title">API Guides</span>
        <% end %>
        <%= form_with url: search_path, method: :get, local: true, class: "site-header__search" do |f| %>
          <%= f.text_field :q, value: params[:q], placeholder: "Search docs",
                                autocomplete: "off", aria: { label: "Search documentation" } %>
        <% end %>
        <%= yield :header %>
        <button type="button"
                class="theme-toggle"
                data-action="click->theme#toggle"
                data-theme-target="button"
                aria-label="Toggle dark mode"></button>
      </div>
    </header>

    <div class="site-shell">
      <%# Module-nav is lazy-loaded into this frame and marked permanent
          so it loads once per session and survives Turbo navigations
          (no blank-then-refill flicker as you click through it). Empty
          in the initial HTML — content pages stay content-first for
          crawlers and no-JS clients. %>
      <% if nav_package_version %>
        <%# target="_top" so clicking a nav link drives a full-page
            navigation, not a navigation *within* this frame (which would
            try to load the target page's empty nav stub and show
            "content missing"). %>
        <%= turbo_frame_tag "module-nav",
                            src: module_nav_path(source_slug: nav_package_version.source.slug, version: version_url_segment(nav_package_version)),
                            loading: "lazy",
                            target: "_top",
                            data: { turbo_permanent: true } %>
        <button type="button"
                class="module-nav-toggle"
                data-controller="module-nav-toggle"
                data-action="click->module-nav-toggle#toggle"
                aria-label="Toggle module navigation"
                aria-expanded="true">☰</button>
      <% end %>

      <main class="site-main" id="main-content" tabindex="-1">
        <%= yield %>
      </main>
    </div>

    <footer class="site-footer">
      <p>API documentation for the Ruby on Rails framework.</p>
    </footer>

    <%= render "shared/search_palette" %>
  </body>
</html>
