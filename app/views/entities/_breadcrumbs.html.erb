<% segments = breadcrumb_segments(fqn) %>
<nav class="breadcrumbs" aria-label="Namespace path">
  <ol>
    <% segments.each_with_index do |(part, partial_path), idx| %>
      <li>
        <% if idx == segments.size - 1 %>
          <span aria-current="page"><%= part %></span>
        <% else %>
          <%= link_to part, entity_path(version: version_url_segment(@package_version), path: partial_path) %>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
