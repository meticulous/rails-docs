<dialog class="palette"
        aria-labelledby="palette-label"
        data-search-palette-target="dialog"
        data-action="click->search-palette#close keydown->search-palette#onKeydown">
  <div class="palette__inner" data-action="click->search-palette#stopPropagation">
    <label id="palette-label" for="palette-input" class="visually-hidden">Search Rails docs</label>
    <input type="search"
           id="palette-input"
           class="palette__input"
           placeholder="Search Rails docs"
           autocomplete="off"
           autocorrect="off"
           autocapitalize="off"
           spellcheck="false"
           aria-controls="palette-results"
           data-search-palette-target="input"
           data-action="input->search-palette#onInput">
    <ul id="palette-results" class="palette__results" data-search-palette-target="results" role="listbox" aria-label="Search results"></ul>
    <p class="palette__empty muted" data-search-palette-target="empty">
      Type at least 2 characters to search.
    </p>
    <p class="palette__hint muted">
      <kbd>↑↓</kbd> navigate · <kbd>↵</kbd> open · <kbd>esc</kbd> close
    </p>
  </div>
</dialog>
